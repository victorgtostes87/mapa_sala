<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Imprimir Lista de Pacientes</title>
<style>
  body { font-family: 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
  .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 32px 40px; text-align: center; width: 380px; }
  h1 { font-size: 18px; margin-bottom: 8px; }
  p  { color: #94a3b8; font-size: 13px; margin-bottom: 24px; }
  .dias { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  a.dia-btn { display: block; padding: 12px; background: #1d4ed8; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background .15s; }
  a.dia-btn:hover { background: #2563eb; }
  a.back { display: inline-block; margin-top: 20px; font-size: 12px; color: #64748b; text-decoration: none; }
  a.back:hover { color: #e2e8f0; }
</style>
  <script src="https://unpkg.com/lucide@latest"></script>\n</head>
<body>
<div class="card">
  <h1><i data-lucide="printer"></i> Lista de Pacientes</h1>
  <p>Selecione o dia para abrir a lista para impressão / PDF</p>
  <div class="dias">
    {% for d in dias %}
    <a class="dia-btn" href="/imprimir/{{ d }}" target="_blank">{{ dias_pt[d] }}</a>
    {% endfor %}
  </div>
  <a class="back" href="/"><i data-lucide="arrow-left"></i> Voltar ao mapa</a>
</div>
<script>lucide.createIcons();</script>\n</body>
</html>
